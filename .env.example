# ─────────────────────────────────────────────
# S-otify Backend — Variables de entorno
# ─────────────────────────────────────────────
# INSTRUCCIONES: Copiar este archivo a .env:
#   cp .env.example .env
# Luego completar con los valores reales.
# NUNCA committear .env (está en .gitignore)
# ─────────────────────────────────────────────

# Base de datos PostgreSQL (Neon)
# Formato: postgresql://usuario:contraseña@host:5432/db?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/sotify?sslmode=require

# Puerto del servidor (default: 3000)
PORT=3000

# URL del frontend para CORS
# Desarrollo: http://localhost:5173
# Producción: https://snotify.vercel.app
FRONTEND_URL=http://localhost:5173

# Entorno de ejecución
# development | production
NODE_ENV=development
